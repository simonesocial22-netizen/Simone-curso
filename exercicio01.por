programa {
  funcao inicio() {
    cadeia nome = "Ana"
    inteiro idade = 25
    real altura = 1.67
    caracter genero = 'F'
    logico estudante = verdadeiro
    

    //SAIDA DE DADOS

    escreva("Bem-vindo(a), ",nome, "! \n")
    escreva("Seu perfil: \n")
    escreva("Nome:",nome, "\n")
    escreva("Idade:",idade,"\n")
    escreva("Altura:",altura,"\n")
    escreva("Gênero:", genero, "\n")
    escreva("Estudante:", estudante,"\n")





    
    

   


  }
}
