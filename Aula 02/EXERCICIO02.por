programa {
  funcao inicio() {
    cadeia nome 
    real nota1 
    real nota2 
    
    // Entrada de dados

    escreva("Qual o seu nome? \n")
    leia(nome) 

    escreva("Qual a sua primeira nota? \n")
    leia(nota1)

    escreva("Qual a sua segunda nota? \n")
    leia(nota2)

    real mediafinal = (nota1 + nota2)/2

   //Saída de Dados

    escreva("O(a) aluno(a) ", nome, " obteve media final: ", mediafinal)

    
    
  

    
  }
}
