programa {
  funcao inicio() {
     real angulo1 
     real angulo2 
     
     escreva(" digite primeiro angulo: \n")
     leia(angulo1)

     escreva("digite osegundo angulo: \n")
     leia(angulo2)

    real angulo3 = 180 - ( angulo1 + angulo2 ) 


     escreva("O terceiro ângulo é: " , angulo3, " graus")
  }
}
